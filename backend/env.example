PORT=5001
NODE_ENV=development
DATABASE_URL=postgres://user:password@localhost:5433/mydb
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# JWT
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=15m

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-2024-08-06

# Cron
CRON_TZ=America/Argentina/Buenos_Aires
PROGRESSION_CRON_SCHEDULE=0 23 * * 0

# Compliance threshold (decimal, e.g. 0.6 = 60%)
COMPLIANCE_THRESHOLD=0.6

# Resend (transactional email)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=onboarding@resend.dev
APP_URL=http://localhost:5001
APP_DEEP_LINK_SCHEME=trfit

# Firebase Admin SDK (push notifications)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# MercadoPago (subscriptions)
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=your-webhook-secret
MP_PLAN_ID_BASICO=                    # Run npm run mp:setup-plans to generate
MP_PLAN_ID_FULL=
MP_PLAN_ID_PREMIUM=
MP_BACK_URL=trfit://upgrade/success
MP_NOTIFICATION_URL=https://api.trfit.io/webhooks/mp

# Single owner coach (athletes route here on onboarding). Required.
# Create the user via: npx tsx src/scripts/setup-owner-coach.ts <password>
OWNER_COACH_EMAIL=owner@example.com
